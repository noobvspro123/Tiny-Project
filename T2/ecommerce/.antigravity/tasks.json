{
    "version": "2.0.0",
    "tasks": [{
        "label": "Build & Run ecommerce",
        "type": "shell",
        "command": "g++",
        "args": [
            "-std=c++17", "-Wall", "-Wextra", "-O2",
            "-Iinclude", "src\\*.cpp", "-o", "ecommerce.exe"
        ],
        "group": {"kind": "build", "isDefault": true},
        "options": {"cwd": "${workspaceFolder}"},
        "problemMatcher": ["$gcc"]
    }]
}
